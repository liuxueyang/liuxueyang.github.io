&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; cerr &lt;span style="color:#719e07"&gt;&amp;lt;&amp;lt;&lt;/span&gt; &lt;span style="color:#2aa198"&gt;&amp;#34;, &amp;#34;&lt;/span&gt;;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; _print(v...);
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;}
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#719e07"&gt;#ifdef _DEBUG
&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#719e07"&gt;#define debug1(x) cout &amp;lt;&amp;lt; #x &amp;#34; = &amp;#34; &amp;lt;&amp;lt; x &amp;lt;&amp;lt; endl;
&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#719e07"&gt;#define debug2(x, y) cout &amp;lt;&amp;lt; #x &amp;#34; = &amp;#34; &amp;lt;&amp;lt; x &amp;lt;&amp;lt; &amp;#34; &amp;#34; #y &amp;#34; = &amp;#34; &amp;lt;&amp;lt; y &amp;lt;&amp;lt; endl;
