&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#719e07"&gt; cout &amp;lt;&amp;lt; #x &amp;#34; = &amp;#34; &amp;lt;&amp;lt; x &amp;lt;&amp;lt; &amp;#34; &amp;#34; #y &amp;#34; = &amp;#34; &amp;lt;&amp;lt; y &amp;lt;&amp;lt; &amp;#34; &amp;#34; #z &amp;#34; = &amp;#34; &amp;lt;&amp;lt; z &amp;lt;&amp;lt; endl;
