&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#719e07"&gt; cerr &amp;lt;&amp;lt; __func__ &amp;lt;&amp;lt; &amp;#34;:&amp;#34; &amp;lt;&amp;lt; __LINE__ &amp;lt;&amp;lt; &amp;#34; [&amp;#34; &amp;lt;&amp;lt; #x &amp;lt;&amp;lt; &amp;#34;] = [&amp;#34;; \
